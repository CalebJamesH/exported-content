  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<p>We are deploying an off-cycle release of Analytics Cloud today to address bugs affecting the rollout of new Liferay DXP features that depend on Analytics Cloud.<br>\n<br>\n<b>What this means for you:</b><br aria-hidden=\"true\">\n- No Analytics Cloud features are impacted<br aria-hidden=\"true\">\n- No downtime is expected<br aria-hidden=\"true\">\n- No action is required on your part<br>\n<br>\nThis release falls outside our regular Tuesday/Thursday release cadence but is focused exclusively on ensuring new Liferay DXP capabilities work as intended. Your Analytics Cloud environment will continue to operate normally throughout.<br>\n<br>\nWe will post a follow-up confirmation once the release is complete. If you have any questions, please reach out to our support team.</p>"
      },
