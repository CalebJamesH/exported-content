  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Bug Fixes</h2>\n<ul>\n<li>Deployments were not timing out properly</li>\n<li>Typo in Environment info tooltip</li>\n<li>Sorting functionality was not working on Projects page</li>\n<li>Experience 404 and address bar were showing previous user's project path</li>\n<li>IE11 - Delete Service button was re-rendered upon correct service id</li>\n<li>\n<span>Shell was only loaded after the page was refreshed</span><span></span>\n</li>\n<li><span>Autoscaling activities were not showing properly on production</span></li>\n<li><span>Attempting to navigate to /projects/new-deployment was resulting in 500 error</span></li>\n<li><span>Attempting to view project build page for a provisioned project was returning in 500 error</span></li>\n<li>\n<span>Builds page did not load properly, blue loading bar was visible indefinitely</span><span></span>\n</li>\n</ul>"
      },
