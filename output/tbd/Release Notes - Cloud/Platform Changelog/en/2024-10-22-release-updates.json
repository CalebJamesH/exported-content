    {
      "contentFieldValue": {
        "data": "<h3 id=\"h_01HXYS9SF6KY1EAQ17VRHQQAWX\" style=\"box-sizing: border-box; margin: 1.5rem 0px; font-family: ' Source Sans Pro' , ' Source Serif Pro' , -apple-system, BlinkMacSystemFont, ' Segoe UI' , Roboto, ' Helvetica Neue' , Arial, sans-serif; font-weight: 600; line-height: 1.5; color: #2a303e; font-size: 1rem; text-transform: uppercase; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: #ffffff; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\">Added</h3>\n<ul style=\"box-sizing: border-box; margin-top: 0px; margin-bottom: 1rem; color: #2a303e; font-family: ' Source Sans Pro' , ' Source Serif Pro' , -apple-system, BlinkMacSystemFont, ' Segoe UI' , Roboto, ' Helvetica Neue' , Arial, sans-serif; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: #ffffff; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\">\n<li style=\"box-sizing: border-box;\">\n<a href=\"https://liferay.atlassian.net/browse/LCD-41298\">​</a><strong style=\"box-sizing: border-box;\"><a href=\"https://liferay.atlassian.net/browse/LCD-41298\">LCD-41298</a><span> </span>- Allowing users to delete marketplace apps from within the cloud console:</strong><span> Now if you want to remove a marketplace app from your project there is no need to move out of the cloud console and into marketplace! You can just go to the Services page in the environment it was installed and remove it! Saving up a lot of time!</span>\n</li>\n</ul>\n<h3 id=\"h_01HXYS9NRE5H6PTZ9Y99PF8QQH\" style=\"box-sizing: border-box; margin: 1.5rem 0px; font-family: ' Source Sans Pro' , ' Source Serif Pro' , -apple-system, BlinkMacSystemFont, ' Segoe UI' , Roboto, ' Helvetica Neue' , Arial, sans-serif; font-weight: 600; line-height: 1.5; color: #2a303e; font-size: 1rem; text-transform: uppercase; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: #ffffff; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\">Bug Fixes</h3>\n<ul class=\"ak-ul\" style=\"box-sizing: border-box; margin-top: 0px; margin-bottom: 1rem; color: #2a303e; font-family: ' Source Sans Pro' , ' Source Serif Pro' , -apple-system, BlinkMacSystemFont, ' Segoe UI' , Roboto, ' Helvetica Neue' , Arial, sans-serif; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: #ffffff; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\">\n<li style=\"box-sizing: border-box;\">\n<strong style=\"box-sizing: border-box;\"><a style=\"box-sizing: border-box; color: #0b5fff; text-decoration: none; background-color: transparent;\" href=\"https://liferay.atlassian.net/browse/LCD-42227\" target=\"_blank\" rel=\"noopener noreferrer\">LCD-42227</a><span> </span>- Service readiness status bug:<span> </span></strong>Fixed an issue where the service was already available but it was sometimes being signaled as pending.</li>\n</ul>"
      },
