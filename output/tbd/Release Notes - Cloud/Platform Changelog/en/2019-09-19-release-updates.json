  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Changed</h2>\n<ul>\n<li>Show backup list on Disaster Recovery even if Production environment doesn't have any backups</li>\n</ul>\n<h2>Fixed</h2>\n<ul>\n<li>Fix timeout requests causing slowness when navigating between pages</li>\n<li>Fix Shell view not working after resize</li>\n<li>Fix unreadable text when Shell is disconnected</li>\n<li>Fix activity date on Scale page</li>\n<li>Fix the wrong number of instances on Scale page</li>\n<li>Fix 500 error when adding a new environment</li>\n<li>Fix wrong topbar environment alignment on certain pages</li>\n<li>Fix error when attempting to add custom domains that exceed quota</li>\n<li>Fix quotas for services not deployed and hidden environments</li>\n<li>Fix CLI reporting that build failed even when all builds succeed</li>\n</ul>"
      },
