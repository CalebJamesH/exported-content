  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h1>Adds</h1>\n<ul>\n<li>Add new OpenVPN service whenever there's a new VPN connection</li>\n</ul>\n<h1>Changes</h1>\n<ul>\n<li>Deployments that do not contain a build are no longer displayed</li>\n</ul>\n<h1>Fixes</h1>\n<ul>\n<li>Fix Builds and Deployments pages that were not loading</li>\n<li>Fix \"Contact Support\" link when a backup fails</li>\n</ul>\n<h1>Security</h1>\n<ul>\n<li>Update Dockerfile detection to avoid inheriting from an internal image that exposes secrets</li>\n</ul>"
      },
