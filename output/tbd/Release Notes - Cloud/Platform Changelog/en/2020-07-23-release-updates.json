  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Add</h2>\n<ul>\n<li>Create project secrets for read only user</li>\n<li>New location map for us-east4</li>\n</ul>\n<h2>Improvements</h2>\n<ul>\n<li>Design improvements for Activities</li>\n<li>Design improvements for service page dropdown menu</li>\n<li>Design improvements for Services </li>\n<li>Design improvements for Settings</li>\n<li><span>AM and PM are in uppercase, on Backups page</span></li>\n</ul>\n<h2>Bugs</h2>\n<ul>\n<li>The user was encountering a 500 error, when trying access Overview page</li>\n<li>Customer was trying to import big lar files without success</li>\n<li>Users were seeing the manual backup information even when they have no permission to do perform a manual backup</li>\n<li>The Cloud CDN was staying active after change the flat CDN to false</li>\n<li>Alerts badge was flashing while VPN connects</li>\n<li>Date format was missing comma between day and year, on Backups page</li>\n<li>Autoscale dot was not appearing and staying until autoscale is disabled</li>\n</ul>"
      },
