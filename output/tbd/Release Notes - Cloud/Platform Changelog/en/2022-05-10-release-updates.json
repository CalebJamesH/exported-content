  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Bug</h2>\n<ul>\n<li>Uploaded backup does not display in dr environment</li>\n<li>Deprecated liferay configuration used in 7.3 and 7.4 images for ES mode</li>\n<li>Google service accounts are not cleaned up by weekly cleanup tasks</li>\n<li>need to use LTS dxp images in project provisioning</li>\n<li>Blank page rendered when ClusterMap doesn't have the current region implemented</li>\n</ul>\n<h2>Improvement</h2>\n<ul>\n<li>publishNotReadyAddressesForCluster defaults to false. For more details <a href=\"https://help.liferay.com/hc/pt/articles/360057959792-How-to-stop-the-new-instances-of-the-Liferay-service-from-receiving-requests-during-a-deployment\" target=\"_self\">follow this link</a> </li>\n</ul>"
      },
