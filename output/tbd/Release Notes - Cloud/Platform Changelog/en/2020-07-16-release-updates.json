  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2> </h2>\n<h2>Improvements</h2>\n<ul>\n<li>Receive feedback when service is downscaling</li>\n</ul>\n<h2>Bugs</h2>\n<ul>\n<li>Bitbucket repository link was incorrect for pushed branches on build page</li>\n<li>Backup upload was failing for migration to cloud</li>\n<li>Restore backup button was remaining disabled, even if the request failed</li>\n<li>Tooltip font-weight texts were not being shown correctly</li>\n<li>Disable auto-scaling banner was appearing when Liferay is restarted</li>\n<li>UI elements were moving or blinking causing glitching effect when loading</li>\n<li>Jenkins Pipeline was failing to rebuild from \"Create DXP Cloud Build\" and \"Deploy to Console\"</li>\n</ul>"
      },
