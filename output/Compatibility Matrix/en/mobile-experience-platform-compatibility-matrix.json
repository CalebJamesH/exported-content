idth: 124px;\"><span class=\"wysiwyg-font-size-medium\"><strong>iOS/OSX Versions</strong></span></td>\n</tr>\n</thead>\n<tbody valign=\"top\">\n<tr>\n<td style=\"width: 117px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.3</span></p>\n</td>\n<td style=\"width: 122px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">5.1.x**</font></span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android Studio 4.x<br>Android SDK 21-30<br>Gradle 6.5</span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android phone<br>Android tablet</span></p>\n</td>\n<td style=\"width: 124px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">SDK 21-30</span></p>\n</td>\n</tr>\n<tr>\n<td style=\"width: 117px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.2</span></p>\n</td>\n<td style=\"width: 122px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">5.0.x</font></span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android Studio 3.4<br>Android SDK 21-30<br>Gradle 5.1.1-6.5</span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android phone<br>Android tablet</span></p>\n</td>\n<td style=\"width: 124px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">SDK 21-28</span></p>\n</td>\n</tr>\n<tr>\n<td style=\"width: 117px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.1</span></p>\n</td>\n<td style=\"width: 122px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">4.0.x</font></span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android Studio 3.0</span><br><span class=\"wysiwyg-font-size-medium\">Android SDK 16-27</span><br><span class=\"wysiwyg-font-size-medium\">Gradle 3.0.0</span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android phone</span><br><span class=\"wysiwyg-font-size-medium\">Android tablet</span></p>\n</td>\n<td style=\"width: 124px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">SDK 16-27</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 117px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.0</span></p>\n</td>\n<td style=\"width: 122px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">3.0.x</span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android Studio 3.0</span><br><span class=\"wysiwyg-font-size-medium\">Android SDK 15-27</span><br><span class=\"wysiwyg-font-size-medium\">Gradle 3.0.0</span></p>\n</td>\n<td style=\"width: 139px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">Android phone</span><br><span class=\"wysiwyg-font-size-medium\">Android tablet</span></p>\n</td>\n<td style=\"width: 124px; text-align: left; vertical-align: top; height: 84px;\"><span class=\"wysiwyg-font-size-medium\">SDK 15-27</span></td>\n</tr>\n</tbody>\n</table>\n<p> </p>\n<h3>Xamarin</h3>\n<table class=\"table table-autofit table-list table-nowrap\" style=\"width: 697px; float: left;\">\n<thead>\n<tr style=\"height: 21px;\">\n<td style=\"background-color: #f7f8f9;\"><span class=\"wysiwyg-font-size-medium\"><strong>Liferay Version</strong></span></td>\n<td style=\"background-color: #f7f8f9;\"><span class=\"wysiwyg-font-size-medium\"><strong>Liferay Screens Version</strong></span></td>\n<td style=\"background-color: #f7f8f9;\"><span class=\"wysiwyg-font-size-medium\"><strong>Development Environment</strong></span></td>\n<td style=\"background-color: #f7f8f9;\"><span class=\"wysiwyg-font-size-medium\"><font size=\"2\"><strong>Visual Studio Versions</strong></font></span></td>\n</tr>\n</thead>\n<tbody valign=\"top\">\n<tr>\n<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.2<br>Liferay DXP 7.1</span></p>\n</td>\n<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">4.0.x</font></span></p>\n</td>\n<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">iOS SDK 9.x-11.4</span><br><span class=\"wysiwyg-font-size-medium\">Android SDK 16-25</span><br><span class=\"wysiwyg-font-size-medium\">Mono .NET 5.4.1.6</span></p>\n</td>\n<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">Visual Studio 7.2</font></span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 170px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.0</span></p>\n</td>\n<td style=\"width: 170px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">3.0.x</span></p>\n</td>\n<td style=\"width: 170px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">iOS SDK 9.x-11.1</span><br><span class=\"wysiwyg-font-size-medium\">Android SDK 15-25</span><br><span class=\"wysiwyg-font-size-medium\">Mono .NET 5.4.1.6</span></p>\n</td>\n<td style=\"width: 170px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">Visual Studio 7.2</font></span></p>\n</td>\n</tr>\n</tbody>\n</table>\n<p><span class=\"wysiwyg-font-size-medium\">* Liferay's WebScreenlets leverage native mobile browsers. Due to the limited feature set of these browsers, we cannot assure full compatibility with Liferay DXP. Please check the browser's support policy on features implemented within your mobile application.<br>** Final Version: No new versions will be available for Liferay Screens. </span><span class=\"wysiwyg-font-size-medium\"></span></p>\n<h2>Liferay Push***</h2>\n<table class=\"table table-autofit table-list table-nowrap\" style=\"width: 697px; float: left; height: 216px;\">\n<thead>\n<tr style=\"height: 21px;\">\n<td style=\"background-color: #f7f8f9; height: 22px; width: 337px;\"><span class=\"wysiwyg-font-size-medium\"><strong>Liferay Version</strong></span></td>\n<td style=\"background-color: #f7f8f9; height: 22px; width: 337px;\"><span class=\"wysiwyg-font-size-medium\"><strong>Operating Systems</strong></span></td>\n</tr>\n</thead>\n<tbody valign=\"top\">\n<tr style=\"height: 22px;\">\n<td style=\"width: 337px; text-align: left; vertical-align: top; height: 22px;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.2</span></p>\n</td>\n<td style=\"width: 337px; text-align: left; vertical-align: top; height: 22px;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">iOS 10-11<br>Android SDK 16-29</font></span></p>\n</td>\n</tr>\n<tr style=\"height: 44px;\">\n<td style=\"width: 337px; text-align: left; vertical-align: top; height: 44px;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.1</span></p>\n</td>\n<td style=\"width: 337px; text-align: left; vertical-align: top; height: 44px;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">iOS 10-11<br>Android SDK 16-27 </font></span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 337px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.0</span></p>\n</td>\n<td style=\"width: 337px; text-align: left; vertical-align: top; height: 84px;\">\n<p><span class=\"wysiwyg-font-size-medium\"><font size=\"2\">iOS 8-11 <br>Android SDK 15-27 </font></span></p>\n</td>\n</tr>\n</tbody>\n</table>\n<p><span class=\"wysiwyg-font-size-medium\"><br>*** Client-side library</span></p>\n<p> </p>"
