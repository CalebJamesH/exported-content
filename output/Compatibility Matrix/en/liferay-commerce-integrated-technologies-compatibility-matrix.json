\n<p><strong><span class=\"wysiwyg-font-size-medium\">File Stores</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">AdvancedFileSystemStore<br>DBStore<br>FileSystemStore<br>S3Store</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">AdvancedFileSystemStore</span><br><span class=\"wysiwyg-font-size-medium\">DBStore</span><br><span class=\"wysiwyg-font-size-medium\">FileSystemStore</span><br><span class=\"wysiwyg-font-size-medium\">S3Store</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">AdvancedFileSystemStore</span><br><span class=\"wysiwyg-font-size-medium\">DBStore</span><br><span class=\"wysiwyg-font-size-medium\">FileSystemStore</span><br><span class=\"wysiwyg-font-size-medium\">S3Store</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">File Stores <br>(non-production)</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p> </p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p> </p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">CMISStore</span><br><span class=\"wysiwyg-font-size-medium\">JCRStore</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">Auto Tagging</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\"> TensorFlow 2.0.12<br>Google Cloud Vision<br>Google Cloud Natural Language<br></span><span class=\"wysiwyg-font-size-medium\">MS Cognitive<br>OpenNLP</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">TensorFlow 1.10</span><br><span class=\"wysiwyg-font-size-medium\">Google Cloud Vision<br></span>Google Cloud Natural Language<br><span class=\"wysiwyg-font-size-medium\">MS Cognitive<br>OpenNLP</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p> </p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">LDAP Servers</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Apache Directory Server<br>Microsoft Active Directory Server<br>Novell eDirecrtory<br>OpenLDAP</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Apache Directory Server</span><br><span class=\"wysiwyg-font-size-medium\">Microsoft Active Directory Server</span><br><span class=\"wysiwyg-font-size-medium\">Novell eDirecrtory</span><br><span class=\"wysiwyg-font-size-medium\">OpenLDAP</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Apache Directory Server</span><br><span class=\"wysiwyg-font-size-medium\">Microsoft Active Directory Server</span><br><span class=\"wysiwyg-font-size-medium\">Novell eDirecrtory</span><br><span class=\"wysiwyg-font-size-medium\">OpenLDAP</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">Node Discovery</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">JGroups 4.1.7</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">TCPPing</span><br><span class=\"wysiwyg-font-size-medium\">JDBC_Ping</span><br><span class=\"wysiwyg-font-size-medium\">S3_Ping</span><br><span class=\"wysiwyg-font-size-medium\">UDPPing</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">TCPPing</span><br><span class=\"wysiwyg-font-size-medium\">JDBC_Ping</span><br><span class=\"wysiwyg-font-size-medium\">S3_Ping</span><br><span class=\"wysiwyg-font-size-medium\">UDPPing</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">Preview Generation</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Ghostscript 9.5<br>ImageMagick 7.0.10-29<br>PDFBox 2.0.21<br>HTML5<br>Gifsicle 1.92</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Ghostscript 9.26</span><br><span class=\"wysiwyg-font-size-medium\">ImageMagick 7.0.8-34</span><br><span class=\"wysiwyg-font-size-medium\">PDFBox 2.0.13</span><br><span class=\"wysiwyg-font-size-medium\">Xuggler 5.4</span><br><span class=\"wysiwyg-font-size-medium\">HTML5</span><br><span class=\"wysiwyg-font-size-medium\">Gifsicle 1.90+</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Ghostscript 9.23</span><br><span class=\"wysiwyg-font-size-medium\">ImageMagick 7.0.7-24</span><br><span class=\"wysiwyg-font-size-medium\">PDFBox 2.0.4</span><br><span class=\"wysiwyg-font-size-medium\">Xuggler 5.4</span><br><span class=\"wysiwyg-font-size-medium\">HTML5</span><br><span class=\"wysiwyg-font-size-medium\">Gifsicle 1.90+</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">SAML Identity Providers (IdP)</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">ADFS<br>Liferay DXP<br>Liferay Portal EE<br>Okta<br>OpenAM 13+<br>PingFederate<br>Shibboleth<br>Siteminder</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">ADFS</span><br><span class=\"wysiwyg-font-size-medium\">Liferay DXP<br>Liferay Portal EE</span><br><span class=\"wysiwyg-font-size-medium\">OpenAM 13+</span><br><span class=\"wysiwyg-font-size-medium\">PingFederate</span><br><span class=\"wysiwyg-font-size-medium\">Shibboleth</span><br><span class=\"wysiwyg-font-size-medium\">Siteminder</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">ADFS</span><br><span class=\"wysiwyg-font-size-medium\">Liferay DXP<br>Liferay Portal EE</span><br><span class=\"wysiwyg-font-size-medium\">OpenAM 13+</span><br><span class=\"wysiwyg-font-size-medium\">PingFederate</span><br><span class=\"wysiwyg-font-size-medium\">Shibboleth</span><br><span class=\"wysiwyg-font-size-medium\">Siteminder</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">SAML Identity Providers (IdP)<br>(non-production)</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p> <span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">Search/Indexing</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p>Elasticsearch 7.9+ Remote</p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p> <span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x Remote<br> Elasticsearch 7.3.x - 7.9.x Remote<br></span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x Remote</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">Search/Indexing <br>(non-production)</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 7.9+ Sidecar or Remote</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x Embedded or Remote<br>Elasticsearch 7.3.x - 7.9.x Embedded or Remote</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x <br>Embedded or Remote</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">SSO Standards &amp; Solutions</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">OpenID Connect<br>SAML 2.0<br>Facebook Connect<br>Kerberos<br>OpenAM 13<br>Oracle Access Manager<br>Token-based (Siteminder)</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">SAML 2.0</span><br><span class=\"wysiwyg-font-size-medium\">Facebook</span><br><span class=\"wysiwyg-font-size-medium\">Kerberos</span><br><span class=\"wysiwyg-font-size-medium\">OpenID Connect</span><br><span class=\"wysiwyg-font-size-medium\">OpenAM 13</span><br><span class=\"wysiwyg-font-size-medium\">Oracle Access Manager</span><br><span class=\"wysiwyg-font-size-medium\">Siteminder</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">SAML 2.0</span><br><span class=\"wysiwyg-font-size-medium\"> Facebook</span><br><span class=\"wysiwyg-font-size-medium\"> Kerberos<br>NTLM v2</span><br><span class=\"wysiwyg-font-size-medium\"> Central Authentication Service (CAS) 3.3.x</span><br><span class=\"wysiwyg-font-size-medium\"> OpenID Connect</span><br><span class=\"wysiwyg-font-size-medium\"> OpenAM 13</span><br><span class=\"wysiwyg-font-size-medium\"> Oracle Access Manager</span><br><span class=\"wysiwyg-font-size-medium\"> Siteminder</span></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">SSO Standards &amp; Solutions<br>(non-production)</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Central Authentication Service (CAS)<br>OpenAM 12</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Central Authentication Service (CAS) 3.3.x</span><br><span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><font size=\"2\"> OpenID<br>OpenAM 12 </font></p>\n</td>\n</tr>\n<tr style=\"height: 84px;\">\n<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n<p><strong><span class=\"wysiwyg-font-size-medium\">WebDav Client OS</span></strong></p>\n</td>\n<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">Windows 10</span></p>\n</td>\n<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\"> Windows 10</span></p>\n</td>\n<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n<p><span class=\"wysiwyg-font-size-medium\">OSX<br>Windows 7, 8, and 10<br>Ubuntu 16</span></p>\n</td>\n</tr>\n</tbody>\n</table>\n<p><span class=\"wysiwyg-font-size-small\"> Updated 2020/09/14</span></p>\n<p> </p>\n<p> </p>\n<p> </p>\n<p> </p>\n<p> </p>\n<p> </p>"
