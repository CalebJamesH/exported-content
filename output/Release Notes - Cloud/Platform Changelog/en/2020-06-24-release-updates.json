  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Added</h2>\n<ul>\n<li>Secrets (environment variables with extra security)</li>\n</ul>\n<h2>Bugs</h2>\n<ul>\n<li>LCP Deploy Command was failing on larger builds</li>\n<li>Browser tab environment title was not always updated</li>\n<li>Deployment cards and time column were displaying wrong values<span></span>\n</li>\n<li>When bad credentials or certificates are sent over the VPN, they are displayed \"in progress\" instead of displaying a validation error</li>\n<li>Application logs were not being displayed correctly for deployed services</li>\n<li><span>Timestamp and clock icon not appearing to the right of the activity on IE11</span></li>\n<li>Ellipsis menu on Services Page was not aligned right on IE11</li>\n</ul>"
      },
