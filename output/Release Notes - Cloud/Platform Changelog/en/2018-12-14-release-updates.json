  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h1>Adds</h1>\n<ul>\n<li>Add knowledgeBase and announcements URLs to config and topbar</li>\n</ul>\n<h1>Changes</h1>\n<ul>\n<li>Prevent VPN service from being deleted via UI</li>\n<li>Show proper timestamp tooltip on Deploy Build To page</li>\n<li>Don't show build on logs if there was no build</li>\n</ul>\n<h1>Fixes</h1>\n<ul>\n<li>Fix not found error reason</li>\n<li>Fix VPN Card look and feel</li>\n<li>Fix Missing hover and active interactions</li>\n<li>Fix Services panel links with more than five services</li>\n<li>Fix SSL Certificate activity messages</li>\n<li>Fix character overlap on input matrix</li>\n<li>Fix Wrong error message when creating a service with name VPN</li>\n</ul>\n<h1>Security</h1>\n<ul>\n<li>Fix security issues in package dependencies</li>\n</ul>"
      },
