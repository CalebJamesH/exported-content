  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Added</h2>\n<ul>\n<li>Add ability to Cancel VPN connection</li>\n</ul>\n<h2>Bug</h2>\n<ul>\n<li>Fix VPN getting stuck in \"connecting\" state and unable to edit in \"connecting\" state</li>\n<li>Fix incorrect VPN error when VPN is configured with an invalid certificate</li>\n<li>Fix Dynatrace configuration step failing due to too many requests</li>\n<li>Fix disable/enable Support Access toast missing</li>\n<li>Fix VPN failed status, card, and banner visibility</li>\n<li>Fix issue when interrupted VPN doesn't reconnect</li>\n</ul>\n<h2>Improvement</h2>\n<ul>\n<li>Remove duplicated dates from VPN logs</li>\n<li>Improve onboarding email when it comes to Github info</li>\n</ul>"
      },
