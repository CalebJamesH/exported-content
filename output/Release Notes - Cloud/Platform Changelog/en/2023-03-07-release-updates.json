  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Added</h2>\n<ul>\n<li>Implement GCS Backup Restore Strategy</li>\n<li>Update existing backup routes for GCS compatibility</li>\n<li>UI hint for backup download via CURL for large volumes</li>\n<li>UI hint for backup upload via CURL for large volumes</li>\n<li>Create a temporary hidden page to test the Marketplace flow</li>\n</ul>\n<h2>Bug Fixes</h2>\n<ul>\n<li>Optimize inactive mount cleanup during Backup Restore</li>\n<li>Upgrade Gitlab API plugin from 1.0.6 to 5.0.1-78.v47a_45b_9f78b_7 or higher</li>\n<li>Retry Backup upload on GCS Range Error</li>\n<li>No need to access github credentials for other git hosts</li>\n</ul>"
      },
