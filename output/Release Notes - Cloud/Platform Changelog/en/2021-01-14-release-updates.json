  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Add</h2>\n<ul>\n<li>Unicode support in the DXP Cloud database</li>\n<li>Stream databaseDump instead of extracting files to disk</li>\n</ul>\n<h2><span>Bugs</span></h2>\n<ul>\n<li>Some Backups were not being created since 17th Dec</li>\n<li>VPN Server couldn't be configured by Hostname</li>\n<li>Some deployments were not being completed properly</li>\n<li>Some Backup processes were taking more than 24h</li>\n<li>On Autoscaling Report, the number of default instances was wrong</li>\n</ul>"
      },
