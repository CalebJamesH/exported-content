  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Bug</h2>\n<ul>\n<li>Fixed database server not updating the value of an existing Mysql flag</li>\n<li>Removed JENKINS_EMAIL_NOTIFICATIONS_FROM because it isn't used</li>\n<li>When database snapshot is not-found database dump should be sufficient for backup entry</li>\n<li>Fixed <span>database error when setting </span>\"LCP_GCP_DATABASE_FLAG_DEFAULT_TIME_ZONE\": \"EST\"</li>\n<li>Fixed environments dropdown when user does not have permission</li>\n<li>Fixed Start up errors on liferay-dxp:7.3-5.0.0-rc.1</li>\n<li>Fixed 'Undefined' text appears on Builds and Deployments pages</li>\n<li>Fixed Backup menu button not centered</li>\n</ul>"
      },
