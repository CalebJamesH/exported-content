  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<h2>Add</h2>\n<ul>\n<li>\n<span>New location map for</span> northamerica-northeast1 (Montreal, Canada)</li>\n<li>New website to celebrate DXP Cloud 2-Year Anniversary</li>\n</ul>\n<h2>Bugs</h2>\n<ul>\n<li>Some Builds were failing (Failed to rotate logs)</li>\n<li>Liferay service was not starting up with JDK 11</li>\n<li><span>Local deployment of Liferay was failing to connect to database</span></li>\n<li><span>Liferay was failing to connect to database if properties file has line ending encoded as windows</span></li>\n<li><span>Readiness Probe Configuration Menu was opening and immediately closing</span></li>\n</ul>"
      },
