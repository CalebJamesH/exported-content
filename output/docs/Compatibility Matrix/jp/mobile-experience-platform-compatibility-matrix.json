utofit table-list table-nowrap\" style=\"width: 697px; float: left;\">\n\t<thead>\n\t\t<tr style=\"height: 21px;\">\n\t\t\t<td style=\"background-color: #f7f8f9;\"><span class=\"wysiwyg-font-size-medium\"><strong>Liferay<br>\n\t\t\tバージョン</strong></span></td>\n\t\t\t<td style=\"background-color: #f7f8f9;\"><strong>オペレーティングシステム (OS)</strong></td>\n\t\t</tr>\n\t</thead>\n\t<tbody valign=\"top\">\n\t\t<tr>\n\t\t\t<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.2</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\"> <font size=\"2\"> iOS 10-11<br>\n\t\t\tAndroid SDK 16-29 </font> </span></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.1</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 170px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\"> <font size=\"2\"> iOS 10-11<br>\n\t\t\tAndroid SDK 16-27 </font> </span></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"height: 84px;\">\n\t\t\t<td style=\"width: 170px; text-align: left; vertical-align: top; height: 84px;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Liferay DXP 7.0</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 170px; text-align: left; vertical-align: top; height: 84px;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\"> <font size=\"2\"> iOS 8-11<br>\n\t\t\tAndroid SDK 15-27 </font> </span></p>\n\t\t\t</td>\n\t\t</tr>\n\t</tbody>\n</table>\n\n<p><span class=\"wysiwyg-font-size-medium\">&nbsp;</span></p>\n\n<p>*** クライアントサイドライブラリ</p>\n\n<p><span class=\"wysiwyg-font-size-medium\">&nbsp;</span></p>\n\n<p>&nbsp;</p>"
