    {
      "contentFieldValue": {
        "data": "<p><span style=\"font-weight: 400;\">On the left sidebar navigation of <a href=\"https://support.liferay.com/\" rel=\"noopener noreferrer\" style=\"box-sizing: border-box; color: #0041be; text-decoration: underline; background-color: #ffffff; font-family: ' Source Sans Pro' , ' Source Serif Pro' , -apple-system, BlinkMacSystemFont, ' Segoe UI' , Roboto, ' Helvetica Neue' , Arial, sans-serif; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal;\" target=\"_blank\">Customer Portal</a>, the Activation selection expands into a list of purchased products which can be activated. To activate a product please navigate to the appropriate product activation page.&nbsp;</span></p>\n\n<p><span style=\"font-weight: 400;\">To learn more about how to activate a specific product, please review the following articles:&nbsp;</span></p>\n\n<ul>\n\t<li aria-level=\"1\" style=\"font-weight: 400;\"><a href=\"/w/how-do-i-activate-my-liferay-saas-video-tutorial\">How do I activate my Liferay SaaS product?</a></li>\n\t<li aria-level=\"1\" style=\"font-weight: 400;\"><a href=\"/w/how-do-i-activate-my-liferay-paas-product-video-tutorial\">How do I activate my Liferay PaaS product?&nbsp;</a></li>\n\t<li aria-level=\"1\" style=\"font-weight: 400;\"><a href=\"https://support.liferay.com/w/how-do-i-activate-my-self-hosted-liferay-dxp-portal-product-video-tutorial\" rel=\"noopener\" target=\"_blank\"><span style=\"font-weight: 400;\">How do I activate my DXP or Portal product?</span></a></li>\n\t<li aria-level=\"1\" style=\"font-weight: 400;\"><span style=\"font-weight: 400;\"><a href=\"/w/how-do-i-activate-my-analytics-cloud-product-video-tutorial\" rel=\"noopener\" target=\"_blank\">How do I activate my Analytics Cloud product?</a>&nbsp;</span></li>\n\t<li aria-level=\"1\" style=\"font-weight: 400;\"><a href=\"https://support.liferay.com/w/how-do-i-activate-my-commerce-product-video-tutorial\" rel=\"noopener\" target=\"_blank\"><span style=\"font-weight: 400;\">How do I activate my Commerce product?&nbsp;</span></a></li>\n\t<li aria-level=\"1\" style=\"font-weight: 400;\"><a href=\"https://support.liferay.com/w/how-do-i-activate-my-enterprise-search-product-video-tutorial\" rel=\"noopener\" target=\"_blank\"><span style=\"font-weight: 400;\">How do I activate my Enterprise Search?&nbsp;</span></a></li>\n</ul>"
      },
