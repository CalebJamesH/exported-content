ederate<br>\n\t\t\tShibboleth<br>\n\t\t\tSiteminder</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">ADFS</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Liferay DXP<br>\n\t\t\tLiferay Portal EE</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">OpenAM 13+</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">PingFederate</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Shibboleth</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Siteminder</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">ADFS</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Liferay DXP<br>\n\t\t\tLiferay Portal EE</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">OpenAM 13+</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">PingFederate</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Shibboleth</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Siteminder</span></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"height: 84px;\">\n\t\t\t<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n\t\t\t<p><strong><span class=\"wysiwyg-font-size-medium\">SAML アイデンティティプロバイダ（IdP）<br>\n\t\t\t（非本番）。</span></strong></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"height: 84px;\">\n\t\t\t<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n\t\t\t<p><strong><span class=\"wysiwyg-font-size-medium\">検索・索引</span></strong></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n\t\t\t<p>Elasticsearch 7.9+ リモート</p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x リモート<br>\n\t\t\tElasticsearch 7.3.x - 7.9.x リモート</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x リモート。</span></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"height: 84px;\">\n\t\t\t<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n\t\t\t<p><strong><span class=\"wysiwyg-font-size-medium\">検索・索引<br>\n\t\t\t（ノンプロダクション）</span></strong></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 7.9+ Sidecarまたはリモート</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x Embedded or Remote<br>\n\t\t\tElasticsearch 7.3.x - 7.9.x Embedded or Remote</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">Elasticsearch 6.1.x - 6.8.x<br>\n\t\t\t組み込み型またはリモート型</span></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"height: 84px;\">\n\t\t\t<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n\t\t\t<p><strong><span class=\"wysiwyg-font-size-medium\">SSO規格 &amp; ソリューション</span></strong></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">OpenID Connect<br>\n\t\t\tSAML 2.0<br>\n\t\t\tFacebook Connect<br>\n\t\t\tKerberos<br>\n\t\t\tOpenAM 13<br>\n\t\t\tOracle Access Manager<br>\n\t\t\tトークンベース（Siteminder）。</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">SAML 2.0</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Facebook</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Kerberos</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">OpenID Connect</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">OpenAM 13</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Oracle Access Manager</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">Siteminder</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">SAML 2.0</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\"> Facebook</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\"> Kerberos<br>\n\t\t\tNTLM v2</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\"> Central Authentication Service (CAS) 3.3.x</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\"> OpenID Connect</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\"> OpenAM 13</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\"> Oracle Access Manager</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\"> Siteminder</span></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"height: 84px;\">\n\t\t\t<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n\t\t\t<p><strong><span class=\"wysiwyg-font-size-medium\">SSO標準 &amp; ソリューション<br>\n\t\t\t(非本番)</span></strong></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">中央認証サービス（CAS）<br>\n\t\t\tOpenAM 12</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">中央認証サービス（CAS） 3.3.x</span><br>\n\t\t\t<span class=\"wysiwyg-font-size-medium\">OpenAM 12</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n\t\t\t<p><font size=\"2\">OpenID<br>\n\t\t\tOpenAM 12 </font></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"height: 84px;\">\n\t\t\t<td style=\"width: 165.455px; text-align: left; vertical-align: top;\">\n\t\t\t<p><strong><span class=\"wysiwyg-font-size-medium\">WebDavクライアントOS</span></strong></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 246.364px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">ウィンドウズ10</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 262.727px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\"> ウィンドウズ10</span></p>\n\t\t\t</td>\n\t\t\t<td style=\"width: 223.636px; text-align: left; vertical-align: top;\">\n\t\t\t<p><span class=\"wysiwyg-font-size-medium\">OSX<br>\n\t\t\tWindows 7, 8, 10<br>\n\t\t\tUbuntu 16</span></p>\n\t\t\t</td>\n\t\t</tr>\n\t</tbody>\n</table>\n\n<p><span class=\"wysiwyg-font-size-small\"> 2020/09/14更新</span></p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p>"
