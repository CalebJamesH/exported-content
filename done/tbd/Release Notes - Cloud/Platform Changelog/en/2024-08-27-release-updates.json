  "contentFields": [
    {
      "contentFieldValue": {
        "data": "<div class=\"article-content\">\n<section class=\"article-body\">\n<div class=\"article-content\">\n<section class=\"article-body\">\n<div class=\"article-content\">\n<section class=\"article-body\">\n<div class=\"article-content\">\n<section class=\"article-body\">\n<div class=\"article-content\">\n<section class=\"article-body\">\n<h3 id=\"h_01HXYS9SF6KY1EAQ17VRHQQAWX\">Added</h3>\n<ul>\n<li>​<strong><a href=\"https://liferay.atlassian.net/browse/LCD-38457\">LCD-38457</a> - Increased Search Capability for Builds and Deployments:</strong> Added the ability to search using the build ID or the commit ID on the Builds page and Deployments page, enabling users to quickly and effortlessly locate a specific build or deployment.</li>\n<li>\n<strong><a href=\"https://liferay.atlassian.net/browse/LCD-39975\">LCD-39975</a>, <a href=\"https://liferay.atlassian.net/browse/LCD-39978\">LCD-39978</a>, <a href=\"https://liferay.atlassian.net/browse/LCD-39981\">LCD-39981</a>, <a href=\"https://liferay.atlassian.net/browse/LCD-39982\">LCD-39982</a>, <a href=\"https://liferay.atlassian.net/browse/LCD-39985\">LCD-39985</a>, <a href=\"https://liferay.atlassian.net/browse/LCD-39986\">LCD-39986</a> - Security Fixes: </strong>Addressed security vulnerabilities in several Liferay components, improving our overall security posture and follow best practices.</li>\n</ul>\n<h3 id=\"h_01HXYS9NRE5H6PTZ9Y99PF8QQH\">Bug Fixes</h3>\n<ul class=\"ak-ul\">\n<li>\n<strong><a href=\"https://liferay.atlassian.net/browse/LCD-40585\">LCD-40585</a> - Improved Backup Cleanup Performance: </strong>Improved the performance of the Backup Cleanup Scheduler, significantly reducing wait times and ensuring more reliable data protection for users with frequent auto backups.</li>\n</ul>\n</section>\n</div>\n</section>\n</div>\n</section>\n</div>\n</section>\n</div>\n</section>\n</div>"
      },
